# Option 1: Use Docker Postgres (recommended)
# Run: docker compose up -d postgres
# Then use this URL:
DATABASE_URL=postgresql://lifeos:lifeos_secret@localhost:5432/gemini

# Option 2: Use local PostgreSQL with lifeos role
# First run: psql -U postgres -f scripts/setup_db.sql
# Then use the same URL as above.

# Option 3: Use your existing PostgreSQL user
# Create database: createdb gemini
# DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/gemini

# Production (set on server)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# JWT_SECRET=your-strong-random-secret-at-least-32-chars

# Stripe (use test keys for development)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CLIENT_ID=ca_...  # Optional, for Connect/Treasury
# STRIPE_TREASURY_ENABLED=false
