# Build the frontend with: VITE_API_URL=/api npm run build
# Use /api when the app is served behind Nginx that proxies /api to the backend (same origin).
# If the API is on another host, set the full URL, e.g.:
# VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=/api

# Stripe publishable key (pk_test_ or pk_live_) — safe to expose in frontend
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
